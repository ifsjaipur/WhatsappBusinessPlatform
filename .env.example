# WhatsApp Business API
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=122096753828007153
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_WEBHOOK_VERIFICATION_TOKEN=your_verify_token

# Google Gemini (for AI voice)
GOOGLE_API_KEY=your_gemini_api_key

# OpenAI (for text chatbot)
OPENAI_API_KEY=your_openai_api_key

# n8n Integration (post-call/chat hooks)
N8N_CALL_HOOK_URL=https://workflow.financialskills.in/webhook/call-summary
N8N_CHAT_HOOK_URL=https://workflow.financialskills.in/webhook/chat-summary

# Razorpay (for order payments — optional)
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Dashboard Security
DASHBOARD_PASSWORD=your_secure_password
WEBHOOK_SECRET=your_webhook_secret

# Server
PORT=7860
ENVIRONMENT=production

# Branding (white-label — customise for your business)
APP_NAME=IFS WhatsApp Platform
APP_SHORT_NAME=IFS WhatsApp
BUSINESS_NAME=Institute of Financial Studies
BUSINESS_SHORT=IFS
BUSINESS_CITY=Jaipur
SUPPORT_PHONE=+91 78913 93505

# Campaign Rate Limiting (messages per minute)
CAMPAIGN_RATE_LIMIT=60

# MinIO / S3 Storage (optional — if not configured, media is not downloaded)
MINIO_ENDPOINT=https://minio.yourdomain.com
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET=whatsapp-media
MINIO_REGION=us-east-1
MEDIA_EXPIRY_DAYS=7
